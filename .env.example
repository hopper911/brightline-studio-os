# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
# SQLite (legacy): app uses data/studio.db via lib/db
# Prisma/Postgres (CRM, Projects): set DATABASE_URL and DIRECT_URL
# DATABASE_URL="postgresql://studio:studio_password@localhost:5432/studio_os?schema=public"

# NextAuth / Auth.js v5 (required in production — see DEPLOY.md for Vercel)
# Generate: openssl rand -base64 32
AUTH_SECRET=change_me_to_a_long_random_string
AUTH_URL=http://localhost:3000
# Legacy alias (optional; same value as AUTH_SECRET)
NEXTAUTH_SECRET=change_me_to_a_long_random_string
NEXTAUTH_URL=http://localhost:3000

# Resend (magic-link email sign-in)
RESEND_API_KEY=
EMAIL_FROM="Studio OS <onboarding@example.com>"

# Optional: R2/S3 (for apps/worker publishing pipeline)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=

# Optional: Ollama (local AI)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma3
